PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/jobboard
JWT_SECRET=test

# Email (e.g. Gmail: use App Password; or SMTP host/port for others)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=JobBoard <your-email@gmail.com>

# Base URL of the frontend (for reset password link in emails)
FRONTEND_URL=http://localhost:3000